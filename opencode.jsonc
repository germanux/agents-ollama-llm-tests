{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": false,

  "model": "ollama/qwen25-coder-opencode-16k",
  "small_model": "ollama/qwen25-coder-opencode-16k",

  "default_agent": "plan",
  "subagent_depth": 0,

  "lsp": false,

  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama local - laptop",

      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
        "timeout": 600000,
        "chunkTimeout": 180000
      },

      "models": {
        "qwen25-coder-opencode-16k": {
          "name": "Qwen 2.5 Coder 7B - OpenCode 16K",

          "limit": {
            "context": 16384,
            "output": 1024
          }
        }
      }
    }
  },

  "permission": {
    "*": "deny",

    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny"
    },

    "glob": "allow",
    "grep": "allow",
    "question": "allow",

    "edit": "deny",
    "bash": "deny",
    "task": "deny",
    "skill": "deny",
    "lsp": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "external_directory": "deny",
    "doom_loop": "deny"
  }
}
