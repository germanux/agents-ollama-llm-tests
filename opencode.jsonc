{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": false,
  "share": "disabled",

  "enabled_providers": [
    "ollama-local",
    "ollama-pc"
  ],

  "model": "ollama-local/ornith-opencode-16k",
  "small_model": "ollama-local/ornith-opencode-16k",

  "default_agent": "plan",
  "subagent_depth": 0,
  "lsp": false,

  "provider": {
    "ollama-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama portátil",

      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
        "timeout": 600000,
        "chunkTimeout": 180000
      },

      "models": {
        "qwen3-30b-coder-16k": {
          "name": "qwen3-30b-coder-16k portátil 16K",
          "limit": {
            "context": 16384,
            "output": 4096
          }
        }
      }
    },

    "ollama-pc": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama PC grande",

      "options": {
        "baseURL": "http://192.168.1.7:11434/v1",
        "timeout": 600000,
        "chunkTimeout": 180000
      },

      "models": {
        "ornith-cline-64k": {
          "name": "Ornith 35B PC 64K",
          "limit": {
            "context": 65536,
            "output": 6144
          }
        }
      }
    }
  },

  "watcher": {
    "ignore": [
      ".git/**",
      ".idea/**",
      ".opencode/**",
      ".opencode-runtime/**",
      ".cline-config/**",
      ".cline-runtime/**",
      ".cline-state/**",
      "cline-laptop-remote/**",
      "node_modules/**",
      "target/**",
      "opencode-scripts/**",
      "opencode.jsonc",
      "package.json",
      "package-lock.json",
      "README.md",
      "README-OPENCODE-STEP1.md",
      "launch-cline.sh",
      "LICENSE",
      "*.log"
    ]
  },

  "permission": {
    "*": "deny",

    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny"
    },

    "glob": "allow",
    "grep": "allow",
    "question": "allow",

    "edit": "deny",
    "bash": "deny",
    "task": "deny",
    "skill": "deny",
    "lsp": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "external_directory": "deny",
    "doom_loop": "deny"
  }
}
