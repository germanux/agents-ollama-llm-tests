{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "enabled_providers": ["ollama"],
  "default_agent": "plan",
  "subagent_depth": 0,
  "permission": {
    "*": "deny",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "question": "allow",
    "edit": "deny",
    "bash": "deny",
    "task": "deny",
    "skill": "deny",
    "lsp": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "external_directory": "deny",
    "doom_loop": "deny"
  }
}
