{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": false,
  "share": "disabled",

  "enabled_providers": [
    "ollama-local",
    "ollama-pc"
  ],

  "model": "ollama-local/qwen3-30b-coder-16k",
  "small_model": "ollama-local/qwen3-30b-coder-16k",
  "default_agent": "plan",
  "subagent_depth": 0,
  "lsp": false,

  // Model catalogs and their context/output limits are generated by the
  // existing Ollama/OpenCode setup script in .opencode/opencode.json.
  // Do not duplicate those dynamic values in this root configuration.
  "provider": {
    "ollama-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama laptop",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
        "timeout": 600000,
        "chunkTimeout": 180000
      }
    },

    "ollama-pc": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama desktop PC",
      "options": {
        "baseURL": "http://192.168.1.7:11434/v1",
        "timeout": 1200000,
        "chunkTimeout": 300000
      }
    }
  },

  "watcher": {
    "ignore": [
      ".git/**",
      ".idea/**",
      ".opencode/**",
      ".opencode-runtime/**",
      ".cline-config/**",
      ".cline-runtime/**",
      ".cline-state/**",
      "cline-laptop-remote/**",
      "node_modules/**",
      "target/**",
      "opencode-scripts/**",
      "opencode.jsonc",
      "package.json",
      "package-lock.json",
      "README.md",
      "README-OPENCODE-STEP1.md",
      "launch-cline.sh",
      "LICENSE",
      "*.log"
    ]
  },

  "permission": {
    "*": "deny",
    "read": {
      "*": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "question": "allow",
    "edit": "deny",
    "bash": "allow",
    "task": "deny",
    "skill": "deny",
    "lsp": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "external_directory": "deny",
    "doom_loop": "deny"
  }
}
