{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": false,
  "share": "disabled",

  "enabled_providers": [
    "ollama-local",
    "ollama-pc"
  ],

  // Enable all built-in and MCP tools. Keep a few unrelated capabilities disabled.
  // This uses the legacy boolean tool map because the installed ACP/OpenCode parser
  // rejects granular per-agent permission keys in this environment.
  "tools": {
    "*": true,
    "task": false,
    "skill": false,
    "lsp": false,
    "webfetch": false,
    "websearch": false
  },

  // Use the parser-compatible shorthand instead of a granular permission object.
  "permission": "allow",

  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "/home/german/.nvm/versions/node/v22.23.1/bin/npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "chromium",
        "--isolated",
        "--timeout-navigation",
        "120000"
      ],
      "enabled": true,
      "timeout": 30000
    },

    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    }
  },

  "model": "ollama-pc/qwen3-coder-next-direct",
  "small_model": "ollama-pc/qwen3-coder-next-direct",
  "default_agent": "build",
  "subagent_depth": 0,
  "lsp": false,

  "provider": {
    "ollama-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama laptop",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
        "timeout": 600000,
        "chunkTimeout": 180000
      }
    },

    "ollama-pc": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama desktop PC",
      "options": {
        "baseURL": "http://192.168.1.7:11434/v1",
        "timeout": 1200000,
        "chunkTimeout": 300000
      }
    }
  },

  "watcher": {
    "ignore": [
      ".git/**",
      ".idea/**",
      ".opencode/**",
      ".opencode-runtime/**",
      ".cline-config/**",
      ".cline-runtime/**",
      ".cline-state/**",
      "cline-laptop-remote/**",
      "node_modules/**",
      "target/**",
      "opencode-scripts/**",
      "opencode.jsonc",
      "package.json",
      "package-lock.json",
      "README.md",
      "README-OPENCODE-STEP1.md",
      "launch-cline.sh",
      "LICENSE",
      "*.log"
    ]
  }
}
