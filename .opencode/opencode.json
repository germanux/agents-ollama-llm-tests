{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama local",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
        "timeout": 600000
      },
      "models": {
        "gpt-oss-120b-16k": {
          "name": "gpt-oss-120b-16k",
          "limit": {
            "context": 24576,
            "output": 4096
          }
        },
        "ornith-cline-64k": {
          "name": "ornith-cline-64k",
          "limit": {
            "context": 65536,
            "output": 6144
          }
        },
        "ornith-opencode-16k": {
          "name": "ornith-opencode-16k",
          "limit": {
            "context": 16384,
            "output": 4096
          }
        },
        "qwen25-7b-coder-16k": {
          "name": "qwen25-7b-coder-16k",
          "limit": {
            "context": 16384,
            "output": 1024
          }
        },
        "qwen25-7b-coder-agent-16k": {
          "name": "qwen25-7b-coder-agent-16k",
          "limit": {
            "context": 16384,
            "output": 4096
          }
        },
        "qwen3-30b-coder-16k": {
          "name": "qwen3-30b-coder-16k",
          "limit": {
            "context": 16384,
            "output": 4096
          }
        },
        "qwen3-30b-coder-32k": {
          "name": "qwen3-30b-coder-32k",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        },
        "qwen3-coder-next-direct": {
          "name": "qwen3-coder-next-direct",
          "limit": {
            "context": 65536,
            "output": 6144
          }
        },
        "qwen36-35b-16k": {
          "name": "qwen36-35b-16k",
          "limit": {
            "context": 16384,
            "output": 4096
          }
        },
        "qwen36-35b-32k": {
          "name": "qwen36-35b-32k",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        }
      }
    },
    "ollama-pc": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama PC",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
        "timeout": 600000
      },
      "models": {
        "qwen3-coder-next-80b-t025-168k-8k-pc-pc": {
          "name": "qwen3-coder-next-80b-t025-168k-8k-pc-pc",
          "temperature": true,
          "limit": {
            "context": 172032,
            "output": 8192
          }
        }
      }
    }
  }
}
